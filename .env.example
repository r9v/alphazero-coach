# LLM provider — set ONE of the following:
GOOGLE_API_KEY=your-key-here
# ANTHROPIC_API_KEY=your-key-here

# Optional: override the default model for your provider
# LLM_MODEL=gemini-2.5-flash

# Optional: limit total games (0 = unlimited, useful for public demos)
# MAX_GAMES=5

# Optional: Langfuse observability (https://langfuse.com)
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_BASE_URL=https://cloud.langfuse.com
